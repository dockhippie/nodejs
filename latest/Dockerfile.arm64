FROM ghcr.io/dockhippie/alpine:latest-arm64@sha256:cf9a331a57489320224a2c9692a2659c999f3dba3bf6fe2a4f1ccaa9d9935e35

WORKDIR /srv/app

COPY ./overlay /

RUN apk update && \
  apk upgrade && \
  apk add build-base git nodejs-dev nodejs npm yarn file autoconf automake && \
  yarn global add gulp grunt-cli bower && \
  rm -rf /var/cache/apk/*
