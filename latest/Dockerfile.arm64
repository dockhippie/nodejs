FROM ghcr.io/dockhippie/alpine:latest-arm64@sha256:e2917e86e92c034b510c41cd3bdb598a3fe8dfca8be5bce1b8b73c0d06da1eff

WORKDIR /srv/app

COPY ./overlay /

RUN apk update && \
  apk upgrade && \
  apk add build-base git nodejs-dev nodejs npm yarn file autoconf automake && \
  yarn global add gulp grunt-cli bower && \
  rm -rf /var/cache/apk/*
