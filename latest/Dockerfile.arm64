FROM ghcr.io/dockhippie/alpine:latest-arm64@sha256:9647f0f65d3b4e6a567a95a25338f7e4fe02704bda1b5966945540084b5debf9

WORKDIR /srv/app

COPY ./overlay /

RUN apk update && \
  apk upgrade && \
  apk add build-base git nodejs-dev nodejs npm yarn file autoconf automake && \
  yarn global add gulp grunt-cli bower && \
  rm -rf /var/cache/apk/*
