FROM ghcr.io/dockhippie/alpine:latest-amd64@sha256:6ff71f40247b9ad7d7d1ca038635bc783bce7bb9eae66527f70bfd8fca025965

WORKDIR /srv/app

COPY ./overlay /

RUN apk update && \
  apk upgrade && \
  apk add build-base git nodejs-dev nodejs npm yarn file autoconf automake && \
  yarn global add gulp grunt-cli bower && \
  rm -rf /var/cache/apk/*
