FROM ghcr.io/dockhippie/alpine:latest-amd64@sha256:5d78e7da52a41546108e91dc39c48e43ddfa797c06d70b58db516f0fb945a5ef

WORKDIR /srv/app

COPY ./overlay /

RUN apk update && \
  apk upgrade && \
  apk add build-base git nodejs-dev nodejs npm yarn file autoconf automake && \
  yarn global add gulp grunt-cli bower && \
  rm -rf /var/cache/apk/*
