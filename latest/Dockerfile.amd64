FROM ghcr.io/dockhippie/alpine:latest-amd64@sha256:0e411848b0557b0d86eedd27f9723ea192bb8a1d517a2d5a6f8174355ed3a254

WORKDIR /srv/app

COPY ./overlay /

RUN apk update && \
  apk upgrade && \
  apk add build-base git nodejs-dev nodejs npm yarn file autoconf automake && \
  yarn global add gulp grunt-cli bower && \
  rm -rf /var/cache/apk/*
