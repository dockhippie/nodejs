FROM ghcr.io/dockhippie/alpine:latest-amd64@sha256:3654fee32bf6e7801421abec274f7440067db343562634d3ab0424b35dc1a459

WORKDIR /srv/app

COPY ./overlay /

RUN apk update && \
  apk upgrade && \
  apk add build-base git nodejs-dev nodejs npm yarn file autoconf automake && \
  yarn global add gulp grunt-cli bower && \
  rm -rf /var/cache/apk/*
